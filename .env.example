# PostgreSQL
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=aiplatform123
POSTGRES_DB=aiplatform

# Redis
REDIS_PASSWORD=redis123

# NestJS API
DATABASE_URL=postgresql://aiplatform:aiplatform123@localhost:5432/aiplatform
REDIS_URL=redis://:redis123@localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3001

# Mountsea API
MOUNTSEA_API_KEY=your-mountsea-api-key
MOUNTSEA_BASE_URL=https://api.mountsea.ai

# File Storage (S3 compatible)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-platform-uploads
S3_REGION=us-east-1

# Payment
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# Next.js Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
