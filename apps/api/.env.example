NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aiplatform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Mountsea AI API（平台服务端 Key，用于调用 AI 生成接口）
MOUNTSEA_API_KEY=your_mountsea_api_key
MOUNTSEA_BASE_URL=https://api.mountsea.ai

# Mountsea 用户端 API（用于代理登录/积分查询，即 shanhaiapi.com 后端）
MOUNTSEA_USER_API_URL=https://dk.mountsea.ai

# S3 File Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ai-platform-uploads
S3_REGION=us-east-1

# 应用公网地址（重要！图生视频/图生图时图片 URL 必须是外网可访问的地址）
#
# 开发环境：留空即可，API 启动时会自动通过 localtunnel 建立临时隧道
#   若 localtunnel 不可用，也可手动设置：
#     1. ngrok：运行 `ngrok http 3001`，填入输出的 https://xxx.ngrok.io
#     2. cloudflare tunnel：运行 `cloudflared tunnel --url http://localhost:3001`
#
# 生产环境：必须填写真实域名，否则图生视频功能无法使用
#   示例：APP_URL=https://api.yourdomain.com
APP_URL=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Google OAuth（前往 https://console.cloud.google.com 创建）
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# 前端地址（用于 OAuth 回调重定向）
FRONTEND_URL=http://localhost:3000
