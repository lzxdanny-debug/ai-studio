!.env.example
!.env.local.example

# ── 日志 ─────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 运行时 / 上传文件 ─────────────────────────────────────────────────────────
apps/api/uploads/
# 保留目录占位符（让 git 保持目录结构）
!apps/api/uploads/.gitkeep

# ── 测试 & 覆盖率 ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── 编辑器 & 系统 ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo

