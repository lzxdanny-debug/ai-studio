# ── 依赖 ──────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm/

# ── 构建产物 ──────────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo

# ── 环境变量（含密钥，绝不提交） ─────────────────────────────────────────────
.env
.env.local
.env.*.local
